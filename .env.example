# =============================================================================
# Local Development Environment Variables (SECRETS ONLY)
# =============================================================================
#
# SETUP:
#   1. Copy this file: cp .env.example .env.local
#   2. Fill in secret values below
#   3. Create symlink for wrangler: ln -s .env.local .dev.vars
#
# Non-secret config lives in config/*.yaml (not here).
# See docs/ai/RULES.md for the full configuration pattern.
# =============================================================================

DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require

# Fourthwall Storefront API Token
# Get this from Fourthwall Dashboard > Developer Settings
# This is a read-only token safe for client-side use
VITE_FOURTHWALL_TOKEN=

# VIA OAuth Configuration (for Cloudflare Worker)
# MC_OAUTH_CLIENT_ID is now a public var in wrangler.toml [vars], not a secret.
# Production secrets: wrangler secret put MC_OAUTH_CLIENT_SECRET / SESSION_SECRET
MC_OAUTH_CLIENT_SECRET=
SESSION_SECRET=

RESEND_API_KEY=

# MongoDB (for future use)
MONGODB_USER=magnuzno_db_user
MONGODB_PASS=
MONGODB_URI=

CLOUDFLARE_STREAM_TOKEN=
CF_ACCESS_CLIENT_SECRET=
CF_IMAGE_TOKEN=-