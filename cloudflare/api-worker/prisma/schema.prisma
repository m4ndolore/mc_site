datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider        = "prisma-client-js"
  previewFeatures = []
}

model GuildUser {
  id         String   @id @default(uuid()) @db.Uuid
  issuer     String
  subject    String
  email      String?
  name       String?
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz
  lastSeenAt DateTime @default(now()) @map("last_seen_at") @db.Timestamptz

  onboardingProfile OnboardingProfile? @relation("GuildUserOnboarding")

  @@unique([issuer, subject])
  @@index([email])
  @@map("guild_users")
}

model OtpChallenge {
  id        String   @id @default(uuid()) @db.Uuid
  email     String
  code      String
  expiresAt DateTime @map("expires_at") @db.Timestamptz
  verified  Boolean  @default(false)
  attempts  Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@index([email, code])
  @@map("otp_challenges")
}

model OnboardingProfile {
  id            String   @id @default(uuid()) @db.Uuid
  email         String
  name          String
  organization  String?
  areas         String[] @default([])
  outcomes      String[] @default([])
  journeyStage  String?  @map("journey_stage")
  products      String[] @default([])
  source        String?
  roleAssigned  String   @default("restricted") @map("role_assigned")
  viaUserId     String?  @map("via_user_id")
  guildUserId   String?  @unique @map("guild_user_id") @db.Uuid
  guildUser     GuildUser? @relation("GuildUserOnboarding", fields: [guildUserId], references: [id])
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz
  provisionedAt DateTime? @map("provisioned_at") @db.Timestamptz

  @@index([email])
  @@index([viaUserId])
  @@map("onboarding_profiles")
}

model Problem {
  id           String   @id @default(uuid()) @db.Uuid
  title        String
  description  String
  domain       String
  status       String   @default("open")
  ownerId      String   @map("owner_id")
  ownerName    String   @map("owner_name")
  ownerEmail   String?  @map("owner_email")
  requirements String?
  tags         String[] @default([])
  matchCount   Int      @default(0) @map("match_count")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  @@index([status])
  @@index([domain])
  @@index([ownerId])
  @@map("problems")
}

model Company {
  id                String   @id @default(uuid()) @db.Uuid
  legacyAirtableId  String?  @map("legacy_airtable_id")
  name              String
  productName       String?  @map("product_name")
  website           String?
  logoUrl           String?  @map("logo_url")
  cfImageId         String?  @map("cf_image_id")
  location          String?
  description       String?
  missionArea       String?  @map("mission_area")
  warfareDomain     String?  @map("warfare_domain")
  technologyArea    String?  @map("technology_area")
  productType       String?  @map("product_type")
  trlLevel          Int?     @map("trl_level")
  technicalMaturity String?  @map("technical_maturity")
  fundingStage      String?  @map("funding_stage")
  teamSize          String?  @map("team_size")
  pipelineStage     String   @default("applicant") @map("pipeline_stage")
  ctas              String[] @default([])
  // Combine-specific
  cohort            String?
  cohortId          String?  @map("cohort_id")
  cohortLabel       String?  @map("cohort_label")
  tulsaAttended     String?  @map("tulsa_attended")
  combineStandout   String?  @map("combine_standout")
  badgeJudges       String?  @map("badge_judges")
  podRanking        Int?     @map("pod_ranking")
  upvoteCount       Int      @default(0) @map("upvote_count")
  // Structured content (stored as JSON strings)
  synopsisSections  Json?    @map("synopsis_sections")
  synopsisRaw       String?  @map("synopsis_raw")
  competitionScores Json?    @map("competition_scores")
  // Timestamps
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  @@index([pipelineStage])
  @@index([missionArea])
  @@index([name])
  @@map("companies")
}

model WaitlistEntry {
  id        String   @id @default(uuid()) @db.Uuid
  email     String
  surface   String
  source    String?
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@unique([email, surface])
  @@index([surface])
  @@map("waitlist_entries")
}
